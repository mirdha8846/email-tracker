{
  "manifest_version": 3,
  "name": "Stealth Email Tracker",
  "version": "1.0",
  "description": "Track when your emails are opened without the recipient knowing.",
  "permissions": [
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://email-tracker-cy15.onrender.com/*",
    "*://*.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Email Tracker Logs"
  }
}
